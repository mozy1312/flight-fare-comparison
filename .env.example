# =============================================================================
# Flight Fare Comparison — Environment Configuration
# =============================================================================
# Choose your flight data provider (duffel, amadeus, flightapi, travelpayouts, mock)
# Recommended: "duffel" — free test mode, 300+ airlines
# Fallback:    "mock"    — demo data, no API key needed
FLIGHT_PROVIDER=duffel

# =============================================================================
# Duffel (RECOMMENDED — replaces Amadeus)
# Get free API key: https://duffel.com/signup
# Free test mode with sandbox data. $3/order in production.
DUFFEL_API_KEY=your_duffel_api_key_here

# =============================================================================
# Amadeus (LEGACY — decommissioning July 17, 2026)
# Only for existing users. New users should use Duffel.
# Get key: https://developers.amadeus.com
AMADEUS_API_KEY=your_amadeus_api_key_here
AMADEUS_API_SECRET=your_amadeus_api_secret_here

# =============================================================================
# FlightAPI.io (budget-friendly)
# Get key: https://flightapi.io
# Free tier: 20-100 calls/month. Paid from $49/month.
FLIGHTAPI_KEY=your_flightapi_key_here

# =============================================================================
# Travelpayouts (free affiliate data)
# Get token: https://www.travelpayouts.com/developers/api
# Free registration. Cached/aggregated fare data.
TRAVELPAYOUTS_TOKEN=your_travelpayouts_token_here

# =============================================================================
# General Settings
DEFAULT_CURRENCY=EUR
DEBUG=false
