# Amadeus API Credentials (Required)
# Get free API key at: https://developers.amadeus.com/register
AMADEUS_API_KEY=your_amadeus_api_key_here
AMADEUS_API_SECRET=your_amadeus_api_secret_here

# Optional: Travelpayouts token for price trends
TRAVELPAYOUTS_TOKEN=your_travelpayouts_token_here

# Optional: Aviationstack key for flight tracking
AVIATIONSTACK_API_KEY=your_aviationstack_key_here

# Debug mode (true/false)
DEBUG=false
